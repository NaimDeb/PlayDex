###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
DATABASE_URL="mysql://root@127.0.0.1:3306/playdex?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^http?://(localhost|127.0.0.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###


###> External API keys ###
STEAM_API_KEY=your_steam_api_key
STEAM_USERNAME=your_steam_username
STEAM_PASSWORD=your_steam_password
IGDB_ACCESS_TOKEN=your_IGDB_ACCESS_TOKEN
TWITCH_CLIENT_ID=your_TWITCH_CLIENT_ID
###< External API keys ###

###> JWT Token ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_secret_passphrase
###< JWT Token ###

LOCK_DSN=flock

###> symfony/mailer ###
# Transport d'envoi des emails.
#   null://null            -> n'envoie rien (valeur sûre par défaut, à garder en test/CI)
#   smtp://127.0.0.1:1025  -> Mailpit, lancé par docker compose (webmail sur http://localhost:8025)
MAILER_DSN=null://null
###< symfony/mailer ###

###> Notifications ###
# Adresse expéditrice des emails de notification de patchnotes.
MAILER_FROM=no-reply@playdex.local

# Base URL du front. Sert à construire les liens cliquables des emails
# (patchnote, page de désinscription). Sans slash final.
FRONTEND_URL=http://localhost:3000

# Base URL de l'API. Indispensable au poller Steam : il tourne en CLI, donc hors
# contexte HTTP, et ne peut pas deviner le domaine pour signer les liens de
# désinscription. Voir config/packages/routing.yaml (router.default_uri).
BACKEND_URL=http://localhost:8000
###< Notifications ###