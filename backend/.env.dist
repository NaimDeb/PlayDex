# .env.dist — valeurs par défaut embarquées dans l'image pour éviter l'exception de symfony lors de la
# création de l'image
# Pourquoi ce fichier existe :
#

###> symfony/framework-bundle ###
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=changeme
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root@db:3306/playdex?serverVersion=8.4&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://.*$'
###< nelmio/cors-bundle ###

###> External API keys ###
STEAM_API_KEY=
STEAM_USERNAME=
STEAM_PASSWORD=
IGDB_ACCESS_TOKEN=
TWITCH_CLIENT_ID=
###< External API keys ###

###> JWT Token ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=changeme
###< JWT Token ###

LOCK_DSN=flock

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> Notifications ###
# À surcharger en prod : ces valeurs servent uniquement à faire démarrer l'image.
# MAILER_FROM  : expéditeur des emails de notification
# FRONTEND_URL : liens cliquables dans les emails (patchnote, désinscription)
# BACKEND_URL  : signature des liens de désinscription depuis le poller (CLI, hors HTTP)
MAILER_FROM=no-reply@playdex.local
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
###< Notifications ###
